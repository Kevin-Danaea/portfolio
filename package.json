{
  "name": "kevinaguilera-tech",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "preview:static": "serve .output/public --no-clipboard -p 4173",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "nuxt generate && playwright test"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/sitemap": "^8.0.15",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^3.15.0",
    "nuxt-schema-org": "^6.0.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint": "^0.7.4",
    "@nuxt/test-utils": "^3.15.4",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "@vue/test-utils": "^2.4.6",
    "axe-core": "^4.11.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.0",
    "happy-dom": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "playwright-core": "^1.49.1",
    "prettier": "^3.4.2",
    "serve": "^14.2.6",
    "typescript": "^5.7.2",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  }
}
